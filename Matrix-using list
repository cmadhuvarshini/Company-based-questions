r = int(input("Enter rows:"))
c = int(input("Enter columns:"))
print("Input:")
m = []
for i in range(r):
    x = list(map(int, input().split()))
    m.append(x)
fr = m[0]
print("Output:")
print(*fr, sep=' ')
for i in range(1, r):
    for j in range(c):
        if j == 0:
            m[i][j] = m[i-1][0] + m[i-1][c-1]  
        else:
            m[i][j] = m[i-1][j-1] + m[i-1][j] 
    print(*m[i], sep=' ')
